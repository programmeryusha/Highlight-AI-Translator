# Copy this file to .env.benchmark and fill in real values.
# .env.benchmark is git-ignored.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
GEMINI_API_KEY=AIza...
DASHSCOPE_API_KEY=sk-...
# QWEN_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-v1-...

# Optional. If omitted, Cloud Vision uses Google Cloud ADC via:
# gcloud auth application-default print-access-token
# GOOGLE_OAUTH_ACCESS_TOKEN=
# GOOGLE_CLOUD_QUOTA_PROJECT=

# Optional model/price overrides for the deep comparison benchmark.
# OPENAI_55_MODEL=gpt-5.5
# GEMINI_31_PRO_MODEL=gemini-3.1-pro-preview
# ANTHROPIC_SONNET_MODEL=claude-sonnet-4-6
# ANTHROPIC_OPUS_MODEL=claude-opus-4-7
#
# OPENAI_55_INPUT_PER_MTOK=5
# OPENAI_55_OUTPUT_PER_MTOK=30
# GEMINI_31_PRO_INPUT_PER_MTOK=2
# GEMINI_31_PRO_OUTPUT_PER_MTOK=12
# ANTHROPIC_SONNET_INPUT_PER_MTOK=3
# ANTHROPIC_SONNET_OUTPUT_PER_MTOK=15
# ANTHROPIC_OPUS_INPUT_PER_MTOK=5
# ANTHROPIC_OPUS_OUTPUT_PER_MTOK=25

# Optional normal-mode controls.
# OPENAI_55_NORMAL_REASONING_EFFORT=none
# GEMINI_31_PRO_NORMAL_THINKING_LEVEL=low

# Optional: slow Gemini requests to avoid free-tier 429s.
# GEMINI_REQUEST_DELAY_MS=13000
