{
  "manifest_version": 3,
  "name": "ContextLens",
  "version": "1.0.0",
  "description": "Highlight any text on any page and instantly understand it — in any language.",
  "permissions": ["storage", "contextMenus", "tabs"],
  "commands": {
    "screenshot": {
      "suggested_key": { "default": "Ctrl+Shift+H", "mac": "Command+Shift+H" },
      "description": "Screenshot a region to explain"
    }
  },
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open Highlighter"
  },
  "options_ui": {
    "page": "src/dashboard/dashboard.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
